{
    "tailwindCSS.experimental.classRegex": [
        [
            "cva\\(((?:[^()]|\\([^()]*\\))*)\\)",
            "[\"'`]([^\"'`]*).*?[\"'`]"
        ],
        [
            "cx\\(((?:[^()]|\\([^()]*\\))*)\\)",
            "(?:'|\"|`)([^']*)(?:'|\"|`)"
        ]
    ],
    "tailwind-fold.autoFold": false,
    "oxc.enable.oxfmt": true,
    "eslint.enable": true,
    "eslint.workingDirectories": [
        "${workspaceFolder}/frontend"
    ]
}
